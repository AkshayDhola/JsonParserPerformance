<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
	<PackageId>JsonParserPerformance</PackageId>
	<Version>1.0.0</Version>
	<Authors>Akshay Dhola</Authors>

	<Description>High-performance Protobuf JSON parser for .NET</Description>
	<RepositoryUrl>https://github.com/AkshayDhola/JsonParserPerformance</RepositoryUrl>

	<PackageTags>protobuf json parser performance</PackageTags>
	<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<IncludeSymbols>true</IncludeSymbols>
	<SymbolPackageFormat>snupkg</SymbolPackageFormat>
	<PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Protobuf" Version="3.34.1" />
  </ItemGroup>

</Project>
